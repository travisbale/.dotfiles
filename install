#!/usr/bin/env bash

set -e

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NEOVIM_VERSION="0.12.1"

# Each line: source (relative to dotfiles) -> target (absolute)
LINKS=(
    ".gitconfig                         ~/.gitconfig"
    "zsh/.zshrc                         ~/.zshrc"
    "zsh/.zshenv                        ~/.zshenv"
    "zsh/.zprofile                      ~/.zprofile"
    "tmux/.tmux.conf                    ~/.tmux.conf"
    "tmux/onedark.tmux                  ~/.tmux/themes/onedark.tmux"
    "alacritty/alacritty.toml           ~/.config/alacritty/alacritty.toml"
    "alacritty/onedark.toml             ~/.config/alacritty/onedark.toml"
    "alacritty/gruvbox.toml             ~/.config/alacritty/gruvbox.toml"
    "nvim/init.lua                      ~/.config/nvim/init.lua"
    "nvim/ftplugin                      ~/.config/nvim/ftplugin"
    "nvim/config                        ~/.config/nvim/lua/config"
    "nvim/plugins                       ~/.config/nvim/lua/plugins"
)

link() {
    local src="$DOTFILES/$1"
    local dst="${2/#\~/$HOME}"
    local parent
    parent="$(dirname "$dst")"

    if [ ! -e "$src" ]; then
        echo "SKIP  $1 (source missing)"
        return
    fi

    mkdir -p "$parent"

    # Remove existing symlink or warn if a real file/dir is in the way
    if [ -L "$dst" ]; then
        rm "$dst"
    elif [ -e "$dst" ]; then
        echo "WARN  $dst exists and is not a symlink, skipping"
        return
    fi

    ln -s "$src" "$dst"
    echo "LINK  $dst -> $src"
}

clean_dead_symlinks() {
    echo ""
    echo "Cleaning dead symlinks in ~..."
    local count=0
    while IFS= read -r -d '' f; do
        echo "CLEAN $f"
        rm "$f"
        ((count++))
    done < <(find "$HOME" -maxdepth 1 -type l ! -exec test -e {} \; -print0 2>/dev/null)
    [ "$count" -eq 0 ] && echo "  (none found)"
}

install_apt_packages() {
    # Packages needed for various tools to work:
    # - zsh: the login shell these dotfiles configure
    # - python3-venv: required by Mason to install black
    # - ripgrep: required by Telescope's live_grep
    # - fd-find: faster file search for Telescope (provides `fdfind` binary)
    # - gnupg: provides gpg for signing git commits
    local packages=(zsh python3-venv ripgrep fd-find gnupg)
    local missing=()

    for pkg in "${packages[@]}"; do
        dpkg -s "$pkg" &>/dev/null || missing+=("$pkg")
    done

    if [ "${#missing[@]}" -eq 0 ]; then
        echo "apt packages already installed: ${packages[*]}"
        return
    fi

    echo "Installing apt packages: ${missing[*]}"
    sudo apt-get update -qq
    sudo apt-get install -y "${missing[@]}"
}

install_neovim() {
    local current
    current="$(nvim --version 2>/dev/null | head -1 | grep -oP 'v\K[0-9]+\.[0-9]+\.[0-9]+')" || true

    if [ "$current" = "$NEOVIM_VERSION" ]; then
        echo "Neovim v$NEOVIM_VERSION already installed"
        return
    fi

    echo "Installing Neovim v$NEOVIM_VERSION..."
    local arch
    case "$(uname -m)" in
        x86_64)  arch="x86_64" ;;
        aarch64) arch="aarch64" ;;
        armv7l)  arch="armv7l" ;;
        *)       echo "ERROR: unsupported architecture $(uname -m)"; return 1 ;;
    esac

    local tarball="nvim-linux-${arch}.tar.gz"
    local url="https://github.com/neovim/neovim/releases/download/v${NEOVIM_VERSION}/${tarball}"
    local tmp
    tmp="$(mktemp -d)"

    curl -fsSL "$url" | tar xz -C "$tmp"
    sudo rm -rf /opt/nvim
    sudo mv "$tmp/nvim-linux-${arch}" /opt/nvim
    sudo ln -sf /opt/nvim/bin/nvim /usr/local/bin/nvim
    rm -rf "$tmp"

    echo "Neovim v$NEOVIM_VERSION installed to /opt/nvim"
}

set_default_shell() {
    local zsh_path
    zsh_path="$(command -v zsh)" || { echo "zsh not found, skipping shell change"; return; }

    if [ "$SHELL" = "$zsh_path" ] && [ "$(getent passwd "$USER" | cut -d: -f7)" = "$zsh_path" ]; then
        echo "Default shell already zsh ($zsh_path)"
        return
    fi

    echo "Setting default shell to $zsh_path..."
    if chsh -s "$zsh_path"; then
        echo "Default shell changed to zsh (restart your session to take effect)"
    else
        echo "WARN  chsh failed; run manually: chsh -s $zsh_path"
    fi
}

setup_git_signing() {
    local local_config="$HOME/.gitconfig.local"

    if ! command -v gpg &>/dev/null; then
        echo "WARN  gpg not found, skipping git signing key setup"
        return
    fi

    # Skip if a signing key is already configured and still present in the keyring.
    local existing_key
    existing_key="$(git config --file "$local_config" --get user.signingkey 2>/dev/null)" || true
    if [ -n "$existing_key" ] && gpg --list-secret-keys "$existing_key" &>/dev/null; then
        echo "Git signing key already configured ($existing_key)"
        return
    fi

    # Need an interactive terminal to prompt for the email.
    if [ ! -t 0 ]; then
        echo "WARN  non-interactive run, skipping git signing key setup"
        return
    fi

    local email
    read -rp "Email for git commits (used as git user.email and signing key UID): " email
    if [ -z "$email" ]; then
        echo "WARN  no email entered, skipping git signing key setup"
        return
    fi

    local name
    name="$(git config --get user.name)" || true
    [ -z "$name" ] && name="$email"

    echo "Generating ed25519 GPG signing key for $name <$email>..."
    gpg --batch --passphrase '' --quick-generate-key "$name <$email>" ed25519 sign never

    local keyid
    keyid="$(gpg --list-secret-keys --with-colons "$email" | awk -F: '/^sec:/ {print $5; exit}')"
    if [ -z "$keyid" ]; then
        echo "WARN  could not determine generated key id, skipping git config"
        return
    fi

    git config --file "$local_config" user.email "$email"
    git config --file "$local_config" user.signingkey "$keyid"
    echo "Git signing configured: $keyid ($email) -> $local_config"
    echo "Add the public key to GitHub/GitLab with:"
    echo "  gpg --armor --export $keyid"
}

echo "Installing dotfiles..."
echo ""

for entry in "${LINKS[@]}"; do
    read -r src dst <<< "$entry"
    link "$src" "$dst"
done

clean_dead_symlinks

echo ""
install_apt_packages

echo ""
install_neovim

echo ""
set_default_shell

echo ""
setup_git_signing

echo ""
echo "Done!"
